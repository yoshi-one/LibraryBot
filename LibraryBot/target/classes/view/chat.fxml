<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ChatController"
            style="-fx-background-color: #f5f5f5;"
            prefWidth="450" prefHeight="700">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to bottom, #2C3E50, #34495E); -fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <!-- Icon -->
                <Region style="-fx-background-color: #3498DB; -fx-pref-width: 50; -fx-pref-height: 50; -fx-background-radius: 8;"/>

                <VBox>
                    <Label text="Perpustakaan Digital" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Asisten Virtual Perpustakaan" style="-fx-text-fill: #BDC3C7; -fx-font-size: 12px;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- User Profile Button -->
                <Button text="Ohim Nibos"
                        style="-fx-background-color: #ECF0F1; -fx-background-radius: 20; -fx-padding: 8 15; -fx-text-fill: #2C3E50; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Chat Area -->
    <center>
        <StackPane style="-fx-background-color: #f5f5f5;">
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="chatBox" spacing="15" style="-fx-padding: 20;">
                    <!-- Messages akan ditambahkan di sini secara dinamis -->
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>

    <!-- Bottom Navigation -->
    <bottom>
        <VBox spacing="0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">

            <!-- Input Area -->
            <HBox spacing="10" style="-fx-padding: 15; -fx-background-color: white;">
                <TextField fx:id="inputField"
                           HBox.hgrow="ALWAYS"
                           promptText="Ketik pertanyaan Anda..."
                           style="-fx-background-color: #F8F9FA; -fx-background-radius: 25; -fx-padding: 12 20; -fx-border-color: transparent; -fx-font-size: 14px;"/>

                <Button text="Kirim"
                        onAction="#handleSend"
                        style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 12 25; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;"/>
            </HBox>

            <!-- Bottom Menu -->
            <HBox alignment="CENTER" spacing="0" style="-fx-padding: 10 0; -fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">
                <Button text="📚 Cek Stok Buku"
                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 8 15;"/>

                <Button text="🔍 Cari Buku Fiksi"
                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 8 15;"/>

                <Button text="📖 Semua Katalog"
                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C8D; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 8 15;"/>

                <Button text="📑 Lihat Semua Kategori"
                        style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 15; -fx-cursor: hand; -fx-padding: 8 15;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
